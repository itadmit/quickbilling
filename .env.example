# ─── Database (Neon) ────────────────────────────────────────
DATABASE_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/billinghub?sslmode=require"

# ─── PayPlus (shared with QS10) ─────────────────────────────
# Code reads `_dev` suffix when NODE_ENV !== "production".
# Override with PAYPLUS_FORCE_ENV=production|dev if needed.

# Production (Vercel deploy uses these)
PAYPLUS_API_URL="https://restapi.payplus.co.il/api/v1.0"
PAYPLUS_API_KEY=""
PAYPLUS_SECRET_KEY=""
PAYPLUS_TERMINAL_UID=""
PAYPLUS_CASHIER_UID=""
PAYPLUS_PAYMENT_PAGE_UID=""

# Staging / dev (localhost uses these)
PAYPLUS_API_URL_dev="https://restapidev.payplus.co.il/api/v1.0"
PAYPLUS_API_KEY_dev=""
PAYPLUS_SECRET_KEY_dev=""
PAYPLUS_TERMINAL_UID_dev=""
PAYPLUS_CASHIER_UID_dev=""
PAYPLUS_PAYMENT_PAGE_UID_dev=""

# ─── Upstash QStash ─────────────────────────────────────────
QSTASH_URL="https://qstash-eu-central-1.upstash.io"
QSTASH_TOKEN=""
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""

# ─── Resend (email) ─────────────────────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="billing@quickcommerce.co.il"
EMAIL_ADMIN_BCC="quickshop.israel@gmail.com"

# ─── NextAuth (dashboard) ───────────────────────────────────
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_URL="http://localhost:3000"

# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
